<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Luna AI — Giriş Yap</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="https://i.imgur.com/X4GG8BF.png" type="image/png">
  <script src="https://accounts.google.com/gsi/client" async defer></script>
</head>
<body>
<div class="auth-page">
  <div class="auth-card" style="max-width: 400px; text-align: center;">

    <!-- Logo -->
    <div class="auth-logo" style="margin-bottom: 30px;">
      <img src="https://i.imgur.com/X4GG8BF.png" alt="Luna AI Logo" onerror="this.src='/img/fallback.png'" style="width: 80px; height: 80px; margin-bottom: 20px;">
      <h1 style="font-size: 1.8rem; margin-bottom: 10px;">Luna AI'ya Hoş Geldin</h1>
      <p style="color: var(--text-2); font-size: 0.95rem;">Devam etmek için Google ile giriş yap</p>
    </div>

    <!-- Error -->
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="error-msg" style="margin-bottom: 20px;">
      <span class="material-icons-round" style="font-size:16px; vertical-align:middle; margin-right:4px;">error_outline</span>
      <%= error %>
    </div>
    <% } %>
    <div class="error-msg" id="errorMsg" style="display:none; margin-bottom: 20px;"></div>

    <!-- Google Login Button Container -->
    <div id="g_id_onload"
         data-client_id="337862703898-g9ufpsiulrmutsk223keguk4eetljpf7.apps.googleusercontent.com"
         data-context="signin"
         data-ux_mode="popup"
         data-callback="handleCredentialResponse"
         data-auto_prompt="false">
    </div>

    <div style="display: flex; flex-direction: column; gap: 12px; align-items: center; margin-bottom: 20px;">
      <div class="g_id_signin"
           data-type="standard"
           data-shape="rectangular"
           data-theme="outline"
           data-text="continue_with"
           data-size="large"
           data-logo_alignment="left"
           style="width: 100%; max-width: 400px; display: flex; justify-content: center;">
      </div>

      <a href="/api/auth/discord" style="display: flex; align-items: center; justify-content: center; width: 100%; max-width: 400px; padding: 10px; background-color: #5865F2; color: white; border-radius: 4px; text-decoration: none; font-family: 'Roboto', 'Google Sans', arial, sans-serif; font-weight: 500; font-size: 14px; box-sizing: border-box; height: 40px; border: 1px solid #5865F2;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 127.14 96.36" style="margin-right: 12px; fill: white;">
          <path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1,105.25,105.25,0,0,0,32.19-16.14c2.64-27.38-4.51-51.11-19.32-72.15ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.31,60,73.31,53s5-12.74,11.43-12.74S96.3,46,96.19,53,91.08,65.69,84.69,65.69Z"/>
        </svg>
        Sign in with Discord
      </a>
    </div>

    <p style="font-size:0.78rem; color:var(--text-3); text-align:center; margin-top:20px; line-height:1.5;">
      Giriş yaparak <a href="/terms" style="color:var(--text-2);">Kullanım Şartları</a>'nı kabul ediyorsun.
    </p>

  </div>
</div>

<script>
window.onload = function() {
  const urlParams = new URLSearchParams(window.location.search);
  const error = urlParams.get('error');
  if (error) {
     const errEl = document.getElementById('errorMsg');
     errEl.innerHTML = `<span class="material-icons-round" style="font-size:16px; margin-right:4px; vertical-align:middle;">error_outline</span>${error}`;
     errEl.style.display = 'block';
  }
}

async function handleCredentialResponse(response) {
  const errEl = document.getElementById('errorMsg');
  errEl.style.display = 'none';

  try {
    const res = await fetch('/api/auth/google', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token: response.credential })
    });

    const data = await res.json();
    if (data.success) {
      window.location.href = '/chat';
    } else {
      errEl.innerHTML = `<span class="material-icons-round" style="font-size:16px; margin-right:4px; vertical-align:middle;">error_outline</span>${data.error}`;
      errEl.style.display = 'block';
    }
  } catch (error) {
    console.error("Login attempt failed", error);
    errEl.innerHTML = `<span class="material-icons-round" style="font-size:16px; margin-right:4px; vertical-align:middle;">error_outline</span>Beklenmeyen bir hata oluştu. Lütfen tekrar deneyin.`;
    errEl.style.display = 'block';
  }
}
</script>
</body>
</html>
