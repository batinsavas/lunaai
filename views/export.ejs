<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Luna AI — Veri Dışa Aktar</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="https://i.imgur.com/X4GG8BF.png" type="image/png">
</head>
<body>
<div class="page-layout">
  <%- include('partials/navbar', {active:'settings'}) %>
  <div class="page-content" style="max-width: 800px;">
    <h1 class="page-title">Veri Dışa Aktarma</h1>
    <p class="page-subtitle">Sohbet geçmişinizi ve hesap verilerinizi cihazınıza indirin</p>

    <div class="card" style="margin-bottom:24px;">
      <div style="display:flex; align-items:center; gap:24px;">
        <div style="position:relative; width:80px; height:80px; border-radius:50%; background:rgba(138,180,248,0.1); display:flex; align-items:center; justify-content:center;">
          <span class="material-icons-round" style="color:var(--accent); font-size:32px;">cloud_download</span>
        </div>
        <div>
          <h2 style="font-size:1.3rem; font-weight:700; margin-bottom:8px;">Tüm Sohbetler (<%= conversations.length %>)</h2>
          <p style="color:var(--text-2); font-size:0.95rem; line-height:1.5; margin-bottom:12px;">Formatlardan birini seçerek veritabanındaki tüm JSON kayıtlarınızı dışa aktarabilirsiniz.</p>
          <div style="display:flex; gap:12px; flex-wrap:wrap;">
            <a href="/api/export/conversations" download="luna-export.json" class="btn btn-filled">
              <span class="material-icons-round" style="font-size:16px;">data_object</span> JSON İndir
            </a>
            <button class="btn btn-outline" onclick="exportMarkdown()">
              <span class="material-icons-round" style="font-size:16px;">markdown</span> Markdown (.md)
            </button>
            <button class="btn btn-outline" onclick="exportText()">
              <span class="material-icons-round" style="font-size:16px;">subject</span> Düz Metin (.txt)
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Additional Data Notice -->
    <div class="alert alert-info" style="align-items:flex-start;">
      <span class="material-icons-round" style="font-size:24px; margin-right:8px; margin-top:2px;">info</span>
      <div>
        <h4 style="font-size:0.95rem; font-weight:600; margin-bottom:4px; color:var(--text);">Dosyalar ve Resimler</h4>
        <p style="font-size:0.85rem; color:var(--text-2); line-height:1.5;">Yüklediğiniz dosyalar (resim, pdf, kod vb.) JSON/Markdown exportuna dahil değildir. Onları <b><a href="/archive" style="color:var(--accent);">Dosya Arşivi</a></b> sayfasından indirebilirsiniz.</p>
      </div>
    </div>
  </div>
</div>

<script>
  const convs = <%- JSON.stringify(conversations || []) %>;
  
  function download(filename, text, type) {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([text], { type }));
    a.download = filename;
    a.click();
  }

  function exportMarkdown() {
    let md = `# Luna AI Sohbet Geçmişi\n\nDışa aktarılma tarihi: ${new Date().toLocaleString('tr-TR')}\n\n`;
    convs.forEach((c, i) => {
      md += `## Sohbet ${i+1} (${new Date(c.createdAt).toLocaleString('tr-TR')})\n\n`;
      c.messages.forEach(m => {
        md += `**${m.role === 'user' ? 'Sen' : 'Luna'}:**\n${m.content}\n\n`;
      });
      md += `---\n\n`;
    });
    download('luna-export.md', md, 'text/markdown');
  }

  function exportText() {
    let txt = `Luna AI Sohbet Geçmişi\n======================\n\n`;
    convs.forEach((c, i) => {
      txt += `SOHBET ${i+1} : ${new Date(c.createdAt).toLocaleString('tr-TR')}\n`;
      txt += `-------------------------------------------------\n\n`;
      c.messages.forEach(m => {
        txt += `[${m.role.toUpperCase()}]\n${m.content}\n\n`;
      });
      txt += `\n\n`;
    });
    download('luna-export.txt', txt, 'text/plain');
  }
</script>
</body>
</html>
