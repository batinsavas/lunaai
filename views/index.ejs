<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Luna AI — Yapay Zeka Asistanı</title>
  <meta name="description" content="Luna AI — LunaSoft tarafından geliştirilen LunaB1 modeli ile sohbet, kod yazma ve görsel analiz.">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="https://i.imgur.com/X4GG8BF.png" type="image/png">
</head>
<body>

<!-- Top bar -->
<nav style="position:fixed; top:0; left:0; right:0; z-index:100; padding:12px 32px; display:flex; align-items:center; justify-content:space-between; background:rgba(19,19,20,0.9); backdrop-filter:blur(12px); border-bottom:1px solid var(--border);">
  <div style="display:flex; align-items:center; gap:10px; text-decoration:none;">
    <img src="https://i.imgur.com/X4GG8BF.png" alt="Luna AI" style="width:32px; height:32px; border-radius:8px;" onerror="this.style.display='none'">
    <span style="font-weight:700; font-size:1rem; color:var(--text);">Luna AI</span>
  </div>
  <div style="display:flex; gap:8px;">
    <% if (user) { %>
      <a href="/chat" class="btn btn-filled">Devam Et</a>
    <% } else { %>
      <a href="/login" class="btn btn-outline">Giriş Yap</a>
      <a href="/register" class="btn btn-filled">Ücretsiz Dene</a>
    <% } %>
  </div>
</nav>

<!-- Hero -->
<div class="landing" style="padding-top:100px;">
  <img src="https://i.imgur.com/X4GG8BF.png" alt="Luna AI" class="landing-logo">
  <h1 class="landing-title">Luna AI</h1>
  <p class="landing-sub">
    LunaB1 model ile desteklenen yapay zeka asistanın.<br>
    Kod yaz, görsel analiz et, sohbet et — hepsi tek yerde.
  </p>

  <div class="landing-actions">
    <% if (user) { %>
      <a href="/chat" class="btn btn-filled btn-lg" style="padding:14px 32px; font-size:1rem;">
        <span class="material-icons-round">chat</span>
        Sohbete Devam Et
      </a>
    <% } else { %>
      <a href="/register" class="btn btn-filled" style="padding:14px 32px; font-size:1rem;">
        <span class="material-icons-round">rocket_launch</span>
        Ücretsiz Başla
      </a>
      <a href="/login" class="btn btn-outline" style="padding:14px 28px; font-size:1rem;">
        Giriş Yap
      </a>
    <% } %>
  </div>

  <!-- Feature Cards -->
  <div class="landing-features">
    <div class="card" style="text-align:left;">
      <div style="margin-bottom:14px;">
        <span class="material-icons-round" style="font-size:28px; color:var(--accent-purple);">chat</span>
      </div>
      <h3 style="font-weight:700; margin-bottom:6px;">Akıllı Sohbet</h3>
      <p style="color:var(--text-2); font-size:0.88rem; line-height:1.6;">Türkçe ve 50+ dilde doğal konuşma, anlayışlı ve empatik yanıtlar.</p>
    </div>
    <div class="card" style="text-align:left;">
      <div style="margin-bottom:14px;">
        <span class="material-icons-round" style="font-size:28px; color:var(--accent);">image_search</span>
      </div>
      <h3 style="font-weight:700; margin-bottom:6px;">Görsel Analiz</h3>
      <p style="color:var(--text-2); font-size:0.88rem; line-height:1.6;">Fotoğraf yükle, Luna detaylıca analiz etsin. Metin okuma, nesne tanıma.</p>
    </div>
    <div class="card" style="text-align:left;">
      <div style="margin-bottom:14px;">
        <span class="material-icons-round" style="font-size:28px; color:var(--success);">code</span>
      </div>
      <h3 style="font-weight:700; margin-bottom:6px;">Kod Üretimi</h3>
      <p style="color:var(--text-2); font-size:0.88rem; line-height:1.6;">30+ programlama dili, canlı HTML canvas önizlemesi ve söz dizimi renklendirme.</p>
    </div>
    <div class="card" style="text-align:left;">
      <div style="margin-bottom:14px;">
        <span class="material-icons-round" style="font-size:28px; color:#fdd663;">shield</span>
      </div>
      <h3 style="font-weight:700; margin-bottom:6px;">Luna Accounts</h3>
      <p style="color:var(--text-2); font-size:0.88rem; line-height:1.6;">Güvenli hesap sistemi, sohbet geçmişi ve kişisel profil yönetimi.</p>
    </div>
  </div>

  <p style="color:var(--text-3); font-size:0.78rem; margin-top:60px;">
    © 2026 LunaSoft — Batın Savaş | <a href="/privacy" style="color:var(--text-2);">Gizlilik</a> · <a href="/terms" style="color:var(--text-2);">Şartlar</a>
  </p>
</div>

</body>
</html>
